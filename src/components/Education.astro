---
const education = [
  {
    school: 'University of Minnesota, Twin Cities',
    degree: 'Ph.D. in Chemistry',
    period: 'Aug 2015 — May 2021',
  },
  {
    school: 'VNUHCM - University of Science',
    degree: 'B.S. in Chemistry',
    period: 'Sep 2007 — Sep 2011',
  },
];
---
<section id="education" class="relative z-10 py-24 px-6">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl font-bold text-white mb-12 reveal">
      <span class="text-primary">//</span> Education
    </h2>
    <div class="grid md:grid-cols-2 gap-6 stagger-children">
      {education.map((edu) => (
        <div class="glow-card p-6">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-white">{edu.school}</h3>
              <p class="text-sm text-gray-400">{edu.degree}</p>
            </div>
          </div>
          <span class="text-sm text-primary/70 font-mono">{edu.period}</span>
        </div>
      ))}
    </div>
  </div>
</section>
